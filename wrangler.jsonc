{
  "$schema": "node_modules/wrangler/config-schema.json",
  "main": ".open-next/worker.js",
  "name": "next-template",
  "compatibility_date": "2026-05-01",
  "compatibility_flags": [
    // Enable Node.js API
    // see https://developers.cloudflare.com/workers/configuration/compatibility-flags/#nodejs-compatibility-flag
    "nodejs_compat",
    // Allow to fetch URLs in your app
    // see https://developers.cloudflare.com/workers/configuration/compatibility-flags/#global-fetch-strictly-public
    "global_fetch_strictly_public",
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS",
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      // The service should match the "name" of your worker
      "service": "next-template",
    },
  ],
  // To enable durable cache storage for 'use cache' components:
  // 1. Create an R2 bucket in the Cloudflare dashboard (Storage & Databases → R2)
  // 2. Uncomment the block below and replace <YOUR_BUCKET_NAME>
  // 3. Uncomment the incrementalCache config in open-next.config.ts
  // Time-based and on-demand revalidation may also require OpenNext's
  // DO queue and tag-cache pieces; see the OpenNext Cloudflare caching docs.
  // "r2_buckets": [
  //   {
  //     "binding": "NEXT_INC_CACHE_R2_BUCKET",
  //     "bucket_name": "<YOUR_BUCKET_NAME>",
  //   },
  // ],
  // Uncomment to enable runtime image optimization via next/image.
  // Only needed for user-uploaded or dynamic images — static images
  // should be pre-generated as webp at build time instead.
  // Requires a Cache Rule for /_next/image* to avoid quota drain.
  // See: https://developers.cloudflare.com/images/pricing/
  // "images": {
  //   "binding": "IMAGES",
  // },
  "vars": {
    "SITE_URL": "http://localhost:3000",
  },
  "minify": true,
  "keep_names": false,
  "upload_source_maps": true,
  "keep_vars": true,
  "observability": {
    "enabled": true,
  },
}
