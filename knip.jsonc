{
  "$schema": "https://unpkg.com/knip@6/schema-jsonc.json",
  "entry": ["open-next.config.ts"],
  "ignoreFiles": ["src/hooks/use-mobile.ts"],
  "ignoreDependencies": [
    "@hookform/resolvers",
    "@testing-library/user-event",
    "ai",
    "motion",
    "react-hook-form",
    "recharts",
    "zod",
  ],
  "ignoreIssues": {
    "src/components/ui/**": ["files", "exports", "types"],
  },
  "treatConfigHintsAsErrors": true,
}
