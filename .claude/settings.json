{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(.env*)",
      "Read(.dev.vars*)",
      "Read(**/*.pem)",
      "Read(.wrangler/**)",
      "Edit(.env*)",
      "Edit(.dev.vars*)",
      "Edit(**/*.pem)",
      "Edit(.wrangler/**)",
      "Write(.env*)",
      "Write(.dev.vars*)",
      "Write(**/*.pem)",
      "Write(.wrangler/**)",

      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(yarn *)",

      "Bash(find *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(echo *)"
    ],
    "ask": [
      "Bash(pnpm deploy *)",
      "Bash(pnpm upload *)",
      "Bash(pnpm nuke *)",
      "Bash(pnpm clean *)",
      "Bash(pnpm dlx *)",
      "Bash(pnpm exec *)",
      "Bash(pnpm add *)",
      "Bash(pnpm remove *)",
      "Bash(pnpm up *)",
      "Bash(pnpm update *)",

      "Bash(rm *)",

      "Bash(git push)",
      "Bash(git push *)",
      "Bash(git reset)",
      "Bash(git reset *)"
    ],
    "allow": [
      "WebFetch",
      "WebSearch",

      "mcp__next-devtools__*",

      "Bash(git *)",
      "Bash(gh *)",

      "Bash(pnpm *)",
      "Bash(corepack *)",

      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(wc *)",
      "Bash(mkdir *)",
      "Bash(mv *)",
      "Bash(cp *)",
      "Bash(touch *)",
      "Bash(test *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const p=JSON.parse(require('fs').readFileSync(0,'utf8')).tool_input.file_path;require('child_process').execSync('pnpm exec prettier --write --ignore-unknown '+JSON.stringify(p),{stdio:'ignore'})\" 2>/dev/null; exit 0",
            "async": true
          }
        ]
      }
    ]
  },
  "enabledMcpjsonServers": ["next-devtools", "chrome-devtools", "shadcn"],
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "sandbox": {
    "enabled": true,
    "enableWeakerNetworkIsolation": true
  }
}
